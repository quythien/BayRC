# Ignore everything by default
*

# Track package source, docs, data, paper, analysis
!R/
!R/**
!src/
!src/**
!man/
!man/**
!vignettes/
!vignettes/**
!tests/
!tests/**
!inst/
!inst/**
!data/
!data/**
!DESCRIPTION
!NAMESPACE
!README.md
!NEWS.md
!LICENSE.md
!CITATION.cff
!BayRC-manual.pdf
!.gitignore
!.Rbuildignore

# Claude Code project instructions kept local only (not tracked in git)
CLAUDE.md

# Compiled artifacts (regenerated by R CMD build)
R/RcppExports.R
src/*.o
src/*.so
src/*.dll

# R session junk
**/.DS_Store
**/.Rhistory
**/.Rdata
*.Rproj
.Rproj.user/

# Output and cache
output/
cache/
*.RData.bak

# Paper kept local only (not tracked in git)
paper/
